{
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "public/out",

        "target": "ES2020",
        "module": "nodenext",

        "lib": ["esnext", "dom"],

        "declaration": false,
        "sourceMap": false,
        "removeComments": true,

        "strict": true,
        "skipLibCheck": true
    },

    "exclude": ["**/api", "**/node_modules"]
}
